# This file needs LF line endings to work correctly on Windows.  If you are using Windows, please change the line endings to LF.

# Buiding:
# docker build --tag apk-scan:latest .
#
# Running:
# docker run --rm --interactive --tty apk-scan


FROM cgr.dev/optum.com/chainguard-base:latest
USER root
WORKDIR /root

RUN <<SETUP_BLOCK

# Append the optum.com APK registry
echo 'https://apk.cgr.dev/optum.com/' >> /etc/apk/repositories

# Add security tools
apk add --no-cache syft grype

cat >> $HOME/.shrc <<SHRC_BLOCK
alias ll='ls -alh'
help() {
    case "\${1-}" in
        apk)
            cat $HOME/apk-search.txt
            ;;
        scanapk)
            scanapk --help
            ;;
        *)
            printf "\\n-------------------------------------------------\\n"
            printf "Wolfi APK Package Scanner\\n"
            printf "  scanapk <pkg>              Scan package (summary mode)\\n"
            printf "  scanapk --full <pkg>       All output with vulnerability summary\\n"
            printf "  help apk                   APK search syntax reference\\n"
            printf "  help scanapk               Show scanapk usage\\n"
            printf -- "-------------------------------------------------\\n"
            ;;
    esac
}

scanapk() {
    output_mode="summary"

    while [ "\$#" -gt 0 ]; do
        case "\$1" in
            --summary)
                output_mode="summary"
                ;;
            --full)
                output_mode="full"
                ;;
            --help|-h)
                echo "Usage: scanapk [--summary|--full] <package> [package ...]"
                echo "Default mode is --summary."
                echo "  --summary  Keep apk add output, save Syft/Grype tables, print final Grype report"
                echo "  --full     Print both Syft and Grype tables with the end-of-run summary"
                return 0
                ;;
            --)
                shift
                break
                ;;
            -*)
                echo "Unknown option: \$1"
                return 1
                ;;
            *)
                break
                ;;
        esac
        shift
    done

    if [ "\$#" -lt 1 ]; then
        echo "Usage: scanapk [--summary|--full] <package> [package ...]"
        echo "Creates a throwaway rootfs, installs the requested apk packages, and runs Syft and Grype."
        return 1
    fi

    if [ -n "\${SCANAPK_OUTPUT_DIR-}" ]; then
        output_dir="\${SCANAPK_OUTPUT_DIR}"
    else
        timestamp=\$(date +%Y%m%d%H%M%S)
        output_dir="\${PWD}/scanapk-\${timestamp}"
    fi
    rootfs_dir="\${output_dir}/rootfs"

    mkdir -p "\${rootfs_dir}/etc/apk" || return 1

    echo "Creating scan workspace: \${output_dir}"
    cp /etc/apk/repositories "\${rootfs_dir}/etc/apk/" || return 1
    cp -R /etc/apk/keys "\${rootfs_dir}/etc/apk/" || return 1
    apk add --no-cache --initdb --no-commit-hooks --root "\${rootfs_dir}" "\$@" || return 1

    echo ""
    echo "Scanning package(s): \$*"
    
    if [ "\${output_mode}" = "summary" ]; then
        SYFT_CHECK_FOR_APP_UPDATE=false syft "dir:\${rootfs_dir}" -o table > "\${output_dir}/syft-table.txt" 2> /dev/null
    else
        SYFT_CHECK_FOR_APP_UPDATE=false syft "dir:\${rootfs_dir}" -o table | tee "\${output_dir}/syft-table.txt"
    fi

    if [ "\${output_mode}" = "summary" ]; then
        GRYPE_CHECK_FOR_APP_UPDATE=false grype "dir:\${rootfs_dir}" -o table > "\${output_dir}/grype-table.txt" 2> /dev/null
    else
        GRYPE_CHECK_FOR_APP_UPDATE=false grype "dir:\${rootfs_dir}" -o table | tee "\${output_dir}/grype-table.txt"
    fi

    severity_counts=\$(awk -F '  +' '
        BEGIN { critical=0; high=0; moderate=0; low=0 }
        NR > 1 && NF >= 6 {
            severity=tolower(\$(NF-2))
            if (severity == "critical") critical++
            else if (severity == "high") high++
            else if (severity == "medium" || severity == "moderate") moderate++
            else if (severity == "low") low++
        }
        END { printf "%d %d %d %d\n", critical, high, moderate, low }
    ' "\${output_dir}/grype-table.txt")
    critical_count=\$(printf "%s\n" "\${severity_counts}" | awk '{print \$1}')
    high_count=\$(printf "%s\n" "\${severity_counts}" | awk '{print \$2}')
    moderate_count=\$(printf "%s\n" "\${severity_counts}" | awk '{print \$3}')
    low_count=\$(printf "%s\n" "\${severity_counts}" | awk '{print \$4}')

    echo ""
    echo "Vulnerability overview:"
    echo "  Critical: \${critical_count:-0}"
    echo "  High:     \${high_count:-0}"
    echo "  Moderate: \${moderate_count:-0}"
    echo "  Low:      \${low_count:-0}"
    echo ""
    echo "Final vulnerability report:"
    cat "\${output_dir}/grype-table.txt"

    echo "scanapk \${output_mode} complete for: \$*"
    echo "More detail:"
    echo "  Syft table:   cat \${output_dir}/syft-table.txt"
    echo "  Grype table:  cat \${output_dir}/grype-table.txt"

    if [ -z "\${SCANAPK_SUPPRESS_REPORT_MESSAGE-}" ]; then
        echo "Reports saved to \${output_dir}"
    fi
}

if [ -z "\${SCANAPK_NONINTERACTIVE-}" ]; then
    echo "This is an interactive tool: fetching apk indexes to speed up interactive queries."
    echo ""
    apk update
    echo ""
    echo "-------------------------------------------------"
    echo "APK Package Scanner"
    echo "  scanapk <pkg>              Scan package (summary mode)"
    echo "  scanapk --full <pkg>       All output with vulnerability summary"
    echo "  help apk                   APK search syntax reference"
    echo "  help scanapk               Show scanapk usage"
    echo "-------------------------------------------------"
fi
SHRC_BLOCK

SETUP_BLOCK

COPY apk-search.txt .

# Have interactive /bin/sh sessions load this file automatically.
ENV ENV=/root/.shrc

ENTRYPOINT [ "sh", "-i" ]
