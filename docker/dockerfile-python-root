# This file needs LF line endings to work correctly on Windows.  If you are using Windows, please change the line endings to LF.

ARG JF_EDGE_NODE=edgeinternal1uhg.uhg.com

# User 65532 is a well-known and documented UserID created as part of the Chainguard base image.
# Using this ID is preferred to creating a new one
ARG CHAINGUARD_USER_AND_GROUP=65532

# Adding both FROM statements to the top of the file allows us to re-use the name/alias for the image.
# This promotes better readability, maintainability, and consistency across the Dockerfile.
FROM ${JF_EDGE_NODE}/glb-docker-uhg-loc/uhg-goldenimages/python:3.14-latest-dev AS final
FROM ${JF_EDGE_NODE}/glb-docker-uhg-loc/uhg-goldenimages/python:3.14-latest-dev AS build

# To make use of the JF_EDGE_NODE argument within a build stage, we need to re-declare it here.
# See the docker documentation on scoping for more detail: https://docs.docker.com/build/building/variables/#scoping
ARG CHAINGUARD_USER_AND_GROUP
ARG JF_EDGE_NODE

USER root

# Create and set permissions for shared data directory
RUN mkdir -p /shared_data && chown ${CHAINGUARD_USER_AND_GROUP}:${CHAINGUARD_USER_AND_GROUP} /shared_data
WORKDIR /app

# Create a root folder for the apk install; this needs to be from the prod image
COPY --from=final / /prod

# Create and activate virtual environment properly
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Use Central timezone
ENV TZ=America/Chicago

# Copy requirements first for better layer caching
COPY requirements.txt .

# Install dependencies in the venv during build stage
RUN --mount=type=secret,id=jf-http-auth,env=JF_HTTP_AUTH \
    --mount=type=secret,id=jf-user,env=JF_USER \
    --mount=type=secret,id=jf-token,env=JF_TOKEN <<ER_AUTHENTICATION_BLOCK

export PIP_INDEX_URL="https://${JF_HTTP_AUTH}@${JF_EDGE_NODE}/artifactory/api/pypi/epl-pypi-vir/simple"

/opt/venv/bin/pip install --no-cache-dir --upgrade pip
/opt/venv/bin/pip install --no-cache-dir -r requirements.txt

# Clean up pip cache and temporary files
rm -rf /root/.cache/pip
find /opt/venv -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
find /opt/venv -type f -name "*.pyc" -delete

export HTTP_AUTH="basic:${JF_EDGE_NODE}:${JF_USER}:${JF_TOKEN}"
